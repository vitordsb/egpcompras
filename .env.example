VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google AI Studio — https://aistudio.google.com/app/apikey (free tier)
# OBS: app interno; chave fica no bundle. Migrar pra Edge Function quando for público.
VITE_GEMINI_API_KEY=

# Ollama (provider local opcional). Modelo recomendado: qwen2.5:7b ou llama3.1:8b
# Pré-requisito: rode com CORS liberado → OLLAMA_ORIGINS=* ollama serve
# E baixe o modelo: ollama pull qwen2.5:7b
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=qwen2.5:7b

# Groq (provider cloud, modelos open-source via API gerenciada)
# Free tier: ~30 RPM, 14k RPD. Pegue a chave em https://console.groq.com/keys
# Modelos: llama-3.3-70b-versatile (recomendado), llama-3.1-8b-instant, qwen-2.5-32b-instruct
VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# URL base do portal público do fornecedor.
# Em produção: https://cotacao.grupoegp.com.br
# Em dev (vazio): usa window.location.origin + /cotacao/<token>
VITE_PUBLIC_QUOTE_BASE_URL=
